{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Orbit",
  "version": "0.0.0",
  "identifier": "run.orbit.app",
  "build": {
    "beforeDevCommand": "pnpm --filter @orbit/desktop dev",
    "beforeBuildCommand": "pnpm --filter @orbit/desktop build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Orbit",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 640,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "backgroundColor": "#0A0A0B"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "Your AI agents, in orbit around your work.",
    "longDescription": "Orbit is a cross-platform desktop workspace for managing teams of AI coding agents that communicate and coordinate with each other.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}
